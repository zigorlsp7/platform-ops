# Legacy alias for backwards compatibility.
# Route53 app/api records are no longer managed by platform-ops aws-compose.
# Use this same baseline as prod.tfvars.example.
aws_region = "eu-west-1"

project     = "platform-ops"
environment = "prod"

instance_type = "t3.large"

enable_ssh        = false
ssh_ingress_cidrs = []
key_name          = ""

create_github_oidc_provider = false
github_oidc_provider_arn    = "arn:aws:iam::123456789012:oidc-provider/token.actions.githubusercontent.com"

github_repository  = "your-org/platform-ops"
github_environment = "production"

ssm_ops_parameter_prefix = "/platform-ops/prod/ops"
