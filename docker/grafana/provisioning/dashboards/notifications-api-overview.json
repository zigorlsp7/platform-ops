{
  "uid": "notifications-api-overview",
  "title": "Notifications API Overview",
  "tags": ["notifications", "api", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "30m", "1h", "6h", "12h"]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Notifications Received",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "name": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(notifications_received_total{job=\"notifications-api\"}[1m]))",
          "legendFormat": "received/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Notifications Sent vs Failed",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "name": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(notifications_sent_total{job=\"notifications-api\"}[1m]))",
          "legendFormat": "sent/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(notifications_failed_total{job=\"notifications-api\"}[1m]))",
          "legendFormat": "failed/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "DLQ Rate",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "name": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(notifications_dlq_total{job=\"notifications-api\"}[5m]))",
          "legendFormat": "dlq/s"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Email Send p95 (seconds)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "name": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(notification_send_duration_seconds_bucket{job=\"notifications-api\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory (process RSS)",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "name": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes{job=\"notifications-api\"}",
          "legendFormat": "rss_bytes"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "API Logs (Loki)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "name": "Loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"docker-json-logs\", service=\"api\", filename=~\".*/notifications-app-.*-api-.*\\\\.log\"}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      }
    }
  ]
}
