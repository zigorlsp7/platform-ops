# Production ops stack env (uploaded to SSM path /cv-web/prod/ops)
# Replace CHANGE_ME_* values before running aws-ssm-sync-env.sh.

CV_SHARED_NETWORK=cv_shared

GRAFANA_ADMIN_USER=cv_admin
GRAFANA_ADMIN_PASSWORD=pass
GRAFANA_USERS_ALLOW_SIGN_UP=false
OPENBAO_KV_MOUNT=kv
OPENBAO_SECRET_PATH=cv-web/app
