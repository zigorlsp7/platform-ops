{
  "name": "platform-ops",
  "private": true,
  "version": "0.1.0",
  "description": "Operations and infrastructure for platform environments",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write \".github/**/*.{json,yml,yaml}\" \"docker/**/*.{json,yml,yaml}\" \"docs/**/*.md\" \"infra/**/*.md\" \"README.md\" \"package.json\"",
    "format:check": "prettier --check \".github/**/*.{json,yml,yaml}\" \"docker/**/*.{json,yml,yaml}\" \"docs/**/*.md\" \"infra/**/*.md\" \"README.md\" \"package.json\"",
    "check:secrets": "bash ./scripts/check-secrets.sh",
    "check:shell": "bash ./scripts/check-shell.sh",
    "check:workflows": "bash ./scripts/check-workflows.sh",
    "check:compose": "bash ./scripts/check-compose.sh",
    "check:terraform": "bash ./scripts/check-terraform-fmt.sh",
    "check:hooks": "npm run check:secrets && npm run check:shell && npm run check:workflows && npm run check:compose && npm run check:terraform",
    "local:up": "bash ./scripts/local-stack-up-ops.sh",
    "local:down": "bash ./scripts/local-stack-down-ops.sh",
    "local:reset": "bash ./scripts/local-stack-down-ops.sh --volumes"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.1.0"
  }
}
